          if (angle === -45) textPosition = 'left-12 bottom-12 text-left items-start';
          if (angle === 45) textPosition = 'left-12 top-12 text-left items-start';
          if (angle === 135) textPosition = 'right-12 top-12 text-right items-end';

          return (
            <div 
