const RadialOrbitalTimeline = ({ timelineData }) => {
  const angles = [-135, -45, 45, 135]; // Posições dos quadrantes (Top-Left, Top-Right, Bottom-Right, Bottom-Left)

  return (
    <div className="w-full flex flex-col items-center py-10 overflow-hidden">
      {/* Desktop Radial/Orbital View */}
      <div className="hidden lg:flex relative w-[800px] h-[600px] items-center justify-center">
        {/* Conexões (Linhas SVG entre nós relacionados) */}
        <svg className="absolute inset-0 w-full h-full pointer-events-none z-0">
          <defs>
            <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stopColor="#3b82f6" />
              <stop offset="100%" stopColor="#f97316" />
            </linearGradient>
          </defs>
          {timelineData.map((item, i1) => {
            const a1 = angles[i1];
            const x1 = 400 + 200 * Math.cos((a1 * Math.PI) / 180); // 400 é o centro horizontal (800/2)
            const y1 = 300 + 200 * Math.sin((a1 * Math.PI) / 180); // 300 é o centro vertical (600/2)

            return item.relatedIds.map(targetId => {
              const i2 = timelineData.findIndex(t => t.id === targetId);
              if (i2 === -1) return null;
              const a2 = angles[i2];
              const x2 = 400 + 200 * Math.cos((a2 * Math.PI) / 180);
              const y2 = 300 + 200 * Math.sin((a2 * Math.PI) / 180);

              return (
                <line 
                  key={`${item.id}-${targetId}`}
                  x1={x1} y1={y1} x2={x2} y2={y2}
                  stroke="url(#lineGradient)" 
                  strokeWidth="2"
                  strokeDasharray="6 6"
                  className="opacity-40"
                />
              );
            });
          })}
        </svg>

        {/* Anéis Orbitais de Fundo */}
        <div className="absolute w-[400px] h-[400px] rounded-full border border-dashed border-zinc-700 animate-[spin_60s_linear_infinite]" />
        <div className="absolute w-[550px] h-[550px] rounded-full border border-zinc-800/30" />
        
        {/* Núcleo Central */}
        <div className="absolute z-10 w-36 h-36 rounded-full bg-blue-900/20 border border-blue-500/50 flex flex-col items-center justify-center shadow-[0_0_60px_rgba(59,130,246,0.3)] backdrop-blur-md">
