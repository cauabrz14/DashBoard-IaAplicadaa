  const variants = {
    default: "bg-white text-zinc-950 hover:bg-zinc-200 shadow-md",
    outline: "border border-zinc-700 bg-transparent text-white hover:bg-zinc-800",
    primary: "bg-blue-600 text-white hover:bg-blue-700 shadow-lg shadow-blue-900/20",
    ghost: "bg-transparent text-zinc-400 hover:text-white hover:bg-zinc-800",
  };
  
  const sizes = {
    default: "h-10 px-4 py-2",
